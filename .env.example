# 复制本文件为 .env 后填入真实值，.env 已被 .gitignore 忽略

# ===== LLM provider 注册 =====
# 启用哪些 provider，逗号分隔。
# 加新 provider 步骤：(1) 在 services/llm.py 的 _OPENAI_COMPAT_REGISTRY 添加，
#                     (2) 这里加 _API_KEY 和 _BASE_URL，(3) 把名字加进 LLM_PROVIDERS
LLM_PROVIDERS=deepseek,qwen

# === DeepSeek（推荐做 PRIMARY，主角分身大脑） ===
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# === Qwen 通义（推荐做 SECONDARY/BACKGROUND，赛事算力直接对接） ===
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# === Kimi（可选，长上下文场景备用） ===
# KIMI_API_KEY=
# KIMI_BASE_URL=https://api.moonshot.cn/v1

# === GLM 智谱（可选） ===
# GLM_API_KEY=
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# === StepFun 阶跃（可选） ===
# STEPFUN_API_KEY=
# STEPFUN_BASE_URL=https://api.stepfun.com/v1

# === Doubao 字节豆包（可选） ===
# DOUBAO_API_KEY=
# DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ===== Tier 路由 =====
# 格式: "provider_name:model_name"
# 切换模型 = 改这三行，0 行业务代码变动
#
# PRIMARY  = 主角分身大脑、关键反事实推理。量小但质量要求最高
# SECONDARY = 公司 HR、面试官的对话。量中等
# BACKGROUND = 200+ 竞争者分身、市场环境。量极大，价格敏感
LLM_TIER_PRIMARY=deepseek:deepseek-chat
LLM_TIER_SECONDARY=qwen:qwen-plus
LLM_TIER_BACKGROUND=qwen:qwen-turbo

# 候选切换示例（直接复制覆盖上面三行即可）：
#   全 Qwen 押宝赛事算力:
#     LLM_TIER_PRIMARY=qwen:qwen-max
#     LLM_TIER_SECONDARY=qwen:qwen-plus
#     LLM_TIER_BACKGROUND=qwen:qwen-turbo
#   推理拉满版（牺牲速度换深度）:
#     LLM_TIER_PRIMARY=deepseek:deepseek-reasoner
#     LLM_TIER_SECONDARY=qwen:qwen-plus
#     LLM_TIER_BACKGROUND=qwen:qwen-turbo

# ===== 数据库 =====
POSTGRES_DSN=postgresql://postgres:postgres@localhost:5432/career_multiverse
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333

# ===== 阿里云（D8+ LoRA 微调、D17+ 部署用） =====
ALIYUN_ACCESS_KEY=
ALIYUN_SECRET_KEY=
ALIYUN_OSS_BUCKET=

# ===== 运行时 =====
APP_ENV=dev
LOG_LEVEL=INFO
