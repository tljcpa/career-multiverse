# 春招平行宇宙 · 生产环境配置
# 用法: cp .env.template .env 然后填入真实密钥
# 部署时 deploy.sh 会自动读取项目根目录的 .env

# ===== LLM provider =====
LLM_PROVIDERS=deepseek

# DeepSeek（必填）
DEEPSEEK_API_KEY=你的deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Tier 路由（三档，可以指向同一个模型）
LLM_TIER_PRIMARY=deepseek:deepseek-chat
LLM_TIER_SECONDARY=deepseek:deepseek-chat
LLM_TIER_BACKGROUND=deepseek:deepseek-chat

# ===== 运行时 =====
APP_ENV=production
LOG_LEVEL=INFO
